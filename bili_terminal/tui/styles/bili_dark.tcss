App {
    background: #09111f;
    color: #f4f9ff;
}

App.theme-light {
    background: #fff7fb;
    color: #4a2c39;
}

Screen {
    background: #09111f;
    color: #f4f9ff;
}

Header,
Footer {
    background: #0f1c33;
    color: #dff4ff;
}

#page-shell {
    height: 1fr;
    padding: 1 1 0 1;
    background: #09111f;
}

#page-masthead {
    height: auto;
    padding: 0 2;
    margin-bottom: 1;
    border: round #fb7299;
    background: #10233f;
    color: #fef7fb;
    text-style: bold;
}

#browser-layout,
#detail-layout {
    height: 1fr;
    background: #09111f;
}

.panel {
    padding: 1;
    border: round #314c78;
    background: #0f1729;
}

.panel-main {
    width: 2fr;
    margin: 0 1;
}

#main-pane,
#detail-main-pane {
    padding: 0;
    background: transparent;
    border: none;
}

.panel-side {
    width: 36;
}

#sidebar-pane {
    width: 26;
}

#detail-main-pane {
    width: 2fr;
    margin-right: 1;
}

#detail-side-pane,
#detail-pane {
    width: 1fr;
}

.panel-title,
#feed-section-title {
    color: #8ee1ff;
    text-style: bold;
}

#sidebar-intro,
#screen-subtitle,
#screen-meta,
#detail-meta,
#detail-hint,
#feed-section-hint,
#theme-picker-subtitle,
#theme-picker-hint {
    color: #b9cae8;
}

#sidebar-intro {
    margin-bottom: 1;
}

.surface-card,
#screen-banner,
#detail-summary,
CommentView,
#detail-scroll,
#channel-list,
VideoList,
#theme-picker-list {
    border: round #233f68;
    background: #141f35;
}

#hero-card,
#detail-hero-card {
    height: auto;
    padding: 0 2;
    background: #112540;
    border: round #00a1d6;
    margin-bottom: 0;
}

#feed-card {
    height: 1fr;
    padding: 0 1 1 1;
    background: #0f1a30;
    border: round #233f68;
}

#screen-title,
#detail-title {
    color: #ffffff;
    text-style: bold;
}

#screen-title {
    margin-bottom: 0;
}

#screen-banner,
#detail-meta {
    margin-top: 0;
    padding: 0 1;
    background: #173254;
    border: round #00a1d6;
    color: #eaf9ff;
}

#screen-meta,
#feed-section-title,
#feed-section-hint,
#detail-hint,
CommentView,
AudioBar,
#status-line,
#help-overlay {
    margin-top: 1;
}

#screen-subtitle,
#screen-meta {
    margin-top: 0;
}

#feed-section-title {
    padding: 0 1;
}

#feed-section-hint {
    padding: 0 1;
}

VideoList,
#channel-list,
#detail-scroll {
    height: 1fr;
}

#feed-card VideoList,
#detail-main-pane #detail-scroll {
    margin-top: 0;
}

#feed-card VideoList {
    border: none;
    background: transparent;
}

#detail-summary {
    padding: 1 1;
    color: #eef5ff;
}

#detail-lines,
CommentView,
.theme-picker__item,
.video-list__item,
.channel-item {
    color: #eef5ff;
}

#detail-scroll {
    padding: 0 1;
}

.video-list__item,
.channel-item {
    padding: 0 1 1 1;
}

ListView > ListItem {
    margin-bottom: 0;
}

ListView > ListItem.--highlight {
    background: #1f4e8d;
    color: #ffffff;
    border: round #5ca9ff;
}

#status-line {
    padding: 1;
    margin: 0 1 0 1;
    border: round #00a1d6;
    background: #102747;
    color: #d8f3ff;
}

AudioBar {
    padding: 1;
    margin: 0 1;
    border: round #fb7299;
    background: #2a1630;
    color: #fff7fb;
}

#help-overlay {
    padding: 1;
    margin: 0 1 1 1;
    border: round #5d7ca8;
    background: #0d1830;
    color: #eef5ff;
}

#search-input {
    margin-bottom: 1;
    background: #132545;
    color: #f4f9ff;
    border: round #00a1d6;
}

CommandPalette {
    background: #09111f 72%;
    color: #eef5ff;
}

CommandPalette > Vertical {
    background: #101a2e;
    color: #eef5ff;
}

CommandPalette > .command-palette--help-text {
    color: #b9cae8;
}

CommandPalette > .command-palette--highlight {
    color: #8ee1ff;
}

CommandPalette #--input {
    border: round #00a1d6;
    background: #132545;
    color: #eef5ff;
}

CommandPalette #--input Label,
CommandPalette SearchIcon,
CommandInput,
CommandInput:focus {
    color: #eef5ff;
    background: transparent;
}

CommandInput > .input--cursor {
    background: #8ee1ff;
    color: #09111f;
}

CommandInput > .input--selection {
    background: #1f4e8d;
}

CommandInput > .input--placeholder,
CommandInput > .input--suggestion {
    color: #86a3cc;
}

CommandPalette #--results {
    background: transparent;
    color: #d8e8ff;
}

CommandList {
    background: #101a2e;
    color: #d8e8ff;
    border-bottom: round #233f68;
}

CommandList > .option-list--option {
    color: #d8e8ff;
    background: #101a2e;
}

CommandList > .option-list--option-highlighted {
    background: #1f4e8d;
    color: #ffffff;
}

CommandList > .option-list--option-disabled {
    color: #86a3cc;
}

CommandList > .option-list--option-hover {
    background: #18385f;
}

CommandPalette LoadingIndicator {
    color: #8ee1ff;
    border-bottom: round #233f68;
}

CommandPalette Button {
    background: #132545;
    color: #eef5ff;
    border: round #00a1d6;
}

#theme-picker-dialog {
    width: 72;
    max-width: 88%;
    height: auto;
    border: round #fb7299;
    background: #101c34;
    padding: 1 2;
    align-horizontal: center;
    align-vertical: middle;
}

#theme-picker-title {
    color: #fb7299;
    text-style: bold;
}

#theme-picker-list {
    margin-top: 1;
    height: auto;
    max-height: 8;
}

.hidden {
    display: none;
}

* {
    scrollbar-background: #0d1830;
    scrollbar-background-hover: #0d1830;
    scrollbar-background-active: #0d1830;
    scrollbar-color: #233f68;
    scrollbar-color-hover: #314c78;
    scrollbar-color-active: #00a1d6;
    scrollbar-corner-color: #0d1830;
}

App.theme-light * {
    scrollbar-background: #fff3f8;
    scrollbar-background-hover: #fff3f8;
    scrollbar-background-active: #fff3f8;
    scrollbar-color: #f1c7d8;
    scrollbar-color-hover: #ffb6cf;
    scrollbar-color-active: #fb7299;
    scrollbar-corner-color: #fff3f8;
}

App.theme-claude * {
    scrollbar-background: #f0ede4;
    scrollbar-background-hover: #f0ede4;
    scrollbar-background-active: #f0ede4;
    scrollbar-color: #d9d4c5;
    scrollbar-color-hover: #c8c2b0;
    scrollbar-color-active: #c96442;
    scrollbar-corner-color: #f0ede4;
}

Tooltip {
    background: #132545;
    color: #eef5ff;
    border: round #00a1d6;
}

App.theme-light Tooltip {
    background: #ffffff;
    color: #6f3150;
    border: round #fb7299;
}

App.theme-claude Tooltip {
    background: #f5f2ea;
    color: #2c2a26;
    border: round #c96442;
}

LoadingIndicator {
    color: #8ee1ff;
    background: transparent;
}

App.theme-light LoadingIndicator {
    color: #fb7299;
    background: transparent;
}

App.theme-claude LoadingIndicator {
    color: #c96442;
    background: transparent;
}

App.theme-light Screen {
    background: #fff7fb;
    color: #4a2c39;
}

App.theme-light #page-shell,
App.theme-light #browser-layout,
App.theme-light #detail-layout {
    background: #fff7fb;
}

App.theme-light Header,
App.theme-light Footer {
    background: #ffe2ed;
    color: #8d2d53;
}

App.theme-light #page-masthead {
    background: #fff2f7;
    border: round #fb7299;
    color: #8d2d53;
}

App.theme-light .panel {
    background: #ffffff;
    border: round #f1c7d8;
}

App.theme-light #hero-card,
App.theme-light #detail-hero-card {
    background: #eaf8ff;
    border: round #00a1d6;
}

App.theme-light #feed-card,
App.theme-light #theme-picker-dialog {
    background: #ffffff;
    border: round #f1c7d8;
}

App.theme-light .panel-title,
App.theme-light #feed-section-title,
App.theme-light #screen-title,
App.theme-light #detail-title,
App.theme-light #theme-picker-title {
    color: #00a1d6;
}

App.theme-light #sidebar-intro,
App.theme-light #screen-subtitle,
App.theme-light #screen-meta,
App.theme-light #detail-meta,
App.theme-light #detail-hint,
App.theme-light #feed-section-hint,
App.theme-light #detail-summary,
App.theme-light #detail-lines,
App.theme-light CommentView,
App.theme-light AudioBar,
App.theme-light #status-line,
App.theme-light #help-overlay,
App.theme-light #theme-picker-subtitle,
App.theme-light #theme-picker-hint,
App.theme-light .theme-picker__item,
App.theme-light .video-list__item,
App.theme-light .channel-item {
    color: #6f3150;
}

App.theme-light #screen-banner,
App.theme-light #detail-meta {
    background: #e8f7ff;
    border: round #00a1d6;
    color: #245a73;
}

App.theme-light #detail-summary,
App.theme-light #help-overlay,
App.theme-light #theme-picker-list,
App.theme-light VideoList,
App.theme-light #channel-list,
App.theme-light #detail-scroll,
App.theme-light CommentView {
    background: #fff3f8;
    border: round #ffd1e1;
}

App.theme-light #feed-card VideoList {
    background: transparent;
    border: none;
}

App.theme-light #status-line {
    background: #ffe3ee;
    border: round #fb7299;
    color: #8f2752;
}

App.theme-light AudioBar {
    background: #fff0f6;
    border: round #fb7299;
    color: #7c2448;
}

App.theme-light #search-input {
    background: #fffafb;
    color: #7a2146;
    border: round #fb7299;
}

App.theme-light CommandPalette {
    background: #fff7fb 72%;
    color: #6f3150;
}

App.theme-light CommandPalette > Vertical {
    background: #ffffff;
    color: #6f3150;
}

App.theme-light CommandPalette > .command-palette--help-text {
    color: #8f5771;
}

App.theme-light CommandPalette > .command-palette--highlight {
    color: #00a1d6;
}

App.theme-light CommandPalette #--input {
    border: round #fb7299;
    background: #fffafb;
    color: #7a2146;
}

App.theme-light CommandPalette #--input Label,
App.theme-light CommandPalette SearchIcon,
App.theme-light CommandInput,
App.theme-light CommandInput:focus {
    color: #7a2146;
    background: transparent;
}

App.theme-light CommandInput > .input--cursor {
    background: #fb7299;
    color: #fffafb;
}

App.theme-light CommandInput > .input--selection {
    background: #ffd1e1;
}

App.theme-light CommandInput > .input--placeholder,
App.theme-light CommandInput > .input--suggestion {
    color: #b1728d;
}

App.theme-light CommandPalette #--results {
    background: transparent;
    color: #6f3150;
}

App.theme-light CommandList {
    background: #fff3f8;
    color: #6f3150;
    border-bottom: round #ffd1e1;
}

App.theme-light CommandList > .option-list--option {
    color: #6f3150;
    background: #fff3f8;
}

App.theme-light CommandList > .option-list--option-highlighted {
    background: #ffd1e1;
    color: #7a2146;
}

App.theme-light CommandList > .option-list--option-disabled {
    color: #b1728d;
}

App.theme-light CommandList > .option-list--option-hover {
    background: #ffe3ee;
}

App.theme-light CommandPalette LoadingIndicator {
    color: #fb7299;
    border-bottom: round #ffd1e1;
}

App.theme-light CommandPalette Button {
    background: #fffafb;
    color: #7a2146;
    border: round #fb7299;
}

App.theme-light ListView > ListItem.--highlight {
    background: #ffd1e1;
    color: #7a2146;
    border: round #fb7299;
}

App.theme-claude {
    background: #f0ede4;
    color: #2c2a26;
}

App.theme-claude Screen {
    background: #f0ede4;
    color: #2c2a26;
}

App.theme-claude #page-shell,
App.theme-claude #browser-layout,
App.theme-claude #detail-layout {
    background: #f0ede4;
}

App.theme-claude Header,
App.theme-claude Footer {
    background: #e6e2d6;
    color: #3d3a35;
}

App.theme-claude #page-masthead {
    background: #f5f2ea;
    border: round #d9d4c5;
    color: #c96442;
}

App.theme-claude .panel {
    background: #f5f2ea;
    border: round #d9d4c5;
}

App.theme-claude #hero-card,
App.theme-claude #detail-hero-card {
    background: #f5f2ea;
    border: round #c96442;
}

App.theme-claude #feed-card,
App.theme-claude #theme-picker-dialog {
    background: #f5f2ea;
    border: round #d9d4c5;
}

App.theme-claude .panel-title,
App.theme-claude #feed-section-title,
App.theme-claude #screen-title,
App.theme-claude #detail-title,
App.theme-claude #theme-picker-title {
    color: #c96442;
}

App.theme-claude #sidebar-intro,
App.theme-claude #screen-subtitle,
App.theme-claude #screen-meta,
App.theme-claude #detail-meta,
App.theme-claude #detail-hint,
App.theme-claude #feed-section-hint,
App.theme-claude #detail-summary,
App.theme-claude #detail-lines,
App.theme-claude CommentView,
App.theme-claude AudioBar,
App.theme-claude #status-line,
App.theme-claude #help-overlay,
App.theme-claude #theme-picker-subtitle,
App.theme-claude #theme-picker-hint,
App.theme-claude .theme-picker__item,
App.theme-claude .video-list__item,
App.theme-claude .channel-item {
    color: #6b6862;
}

App.theme-claude #screen-banner,
App.theme-claude #detail-meta {
    background: #ebe7dc;
    border: round #c96442;
    color: #3d3a35;
}

App.theme-claude #detail-summary,
App.theme-claude #help-overlay,
App.theme-claude #theme-picker-list,
App.theme-claude VideoList,
App.theme-claude #channel-list,
App.theme-claude #detail-scroll,
App.theme-claude CommentView {
    background: #f5f2ea;
    border: round #d9d4c5;
}

App.theme-claude #feed-card VideoList {
    background: transparent;
    border: none;
}

App.theme-claude #status-line {
    background: #e6e2d6;
    border: round #d9d4c5;
    color: #3d3a35;
}

App.theme-claude AudioBar {
    background: #ebe7dc;
    border: round #c96442;
    color: #3d3a35;
}

App.theme-claude #search-input {
    background: #ebe7dc;
    color: #2c2a26;
    border: round #c96442;
}

App.theme-claude CommandPalette {
    background: #f0ede4 72%;
    color: #2c2a26;
}

App.theme-claude CommandPalette > Vertical {
    background: #f5f2ea;
    color: #2c2a26;
}

App.theme-claude CommandPalette > .command-palette--help-text {
    color: #8b8680;
}

App.theme-claude CommandPalette > .command-palette--highlight {
    color: #c96442;
}

App.theme-claude CommandPalette #--input {
    border: round #c96442;
    background: #ebe7dc;
    color: #2c2a26;
}

App.theme-claude CommandPalette #--input Label,
App.theme-claude CommandPalette SearchIcon,
App.theme-claude CommandInput,
App.theme-claude CommandInput:focus {
    color: #2c2a26;
    background: transparent;
}

App.theme-claude CommandInput > .input--cursor {
    background: #c96442;
    color: #f5f2ea;
}

App.theme-claude CommandInput > .input--selection {
    background: #ebe7dc;
}

App.theme-claude CommandInput > .input--placeholder,
App.theme-claude CommandInput > .input--suggestion {
    color: #a8a39a;
}

App.theme-claude CommandPalette #--results {
    background: transparent;
    color: #3d3a35;
}

App.theme-claude CommandList {
    background: #f5f2ea;
    color: #3d3a35;
    border-bottom: round #d9d4c5;
}

App.theme-claude CommandList > .option-list--option {
    color: #3d3a35;
    background: #f5f2ea;
}

App.theme-claude CommandList > .option-list--option-highlighted {
    background: #c96442;
    color: #f5f2ea;
}

App.theme-claude CommandList > .option-list--option-disabled {
    color: #a8a39a;
}

App.theme-claude CommandList > .option-list--option-hover {
    background: #ebe7dc;
}

App.theme-claude CommandPalette LoadingIndicator {
    color: #c96442;
    border-bottom: round #d9d4c5;
}

App.theme-claude CommandPalette Button {
    background: #ebe7dc;
    color: #2c2a26;
    border: round #c96442;
}

App.theme-claude ListView > ListItem.--highlight {
    background: #c96442;
    color: #f5f2ea;
    border: round #b0552f;
}
